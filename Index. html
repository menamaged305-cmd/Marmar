            const text = translations[state.lang];

            msgEl.innerText = message;
            cancelBtn.innerText = text.cancel;
            okBtn.innerText = text.deleteProd;

            modal.classList.remove('hidden');

            cancelBtn.onclick = () => {
                modal.classList.add('hidden');
            };

            okBtn.onclick = () => {
                onConfirm();
                modal.classList.add('hidden');
            };
        }

