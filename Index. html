        async function callGemini(userPrompt, systemInstruction = "") {
            const apiKey = ""; // The execution environment handles and injects the API Key at runtime
            // Using the correct supported preview model
            const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;

            const payload = {
                contents: [{ parts: [{ text: userPrompt }] }]
            };

            if (systemInstruction) {
                payload.systemInstruction = {
                    parts: [{ text: systemInstruction }]
                };
            }

            // Exponential backoff strategy up to 5 times (1s, 2s, 4s, 8s, 16s)
            let backoff = 1000;
            for (let retry = 0; retry < 5; retry++) {
                try {
                    const response = await fetch(apiUrl, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (response.ok) {
                        const data = await response.json();
                        return data.candidates?.[0]?.content?.parts?.[0]?.text || "";
                    }
                } catch (err) {
                    console.debug(`Gemini API call failed (attempt ${retry + 1}/5). Retrying in ${backoff}ms...`, err);
                }
                await new Promise(r => setTimeout(r, backoff));
                backoff *= 2;
            }
            throw new Error("Unable to reach Gemini AI services. Please try again later.");
        }

