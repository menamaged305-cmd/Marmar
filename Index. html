            toast.className = "fixed bottom-6 left-6 z-50 bg-slate-900 text-white px-6 py-4 rounded-2xl shadow-2xl flex items-center space-x-3 max-w-md transform translate-y-0 opacity-100 transition-all duration-300";
            setTimeout(() => {
                toast.className = "fixed bottom-6 left-6 z-50 bg-slate-900 text-white px-6 py-4 rounded-2xl shadow-2xl flex items-center space-x-3 max-w-md transform translate-y-20 opacity-0 transition-all duration-300";
            }, 3000);
        }

