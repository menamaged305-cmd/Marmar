        // Handle categories and filters
        function setCategory(cat) {
            state.currentCategory = cat;
            // Clear search filter when choosing category explicitly
            clearAISearchFilter(false); 
            renderCategoryNavigation();
            renderProducts();
            scrollToGrid();
        }

        function renderCategoryNavigation() {
            const text = translations[state.lang];
            const categories = [
                { id: 'all', label: text.all },
                { id: 'men', label: text.men },
                { id: 'women', label: text.women },
                { id: 'children', label: text.children }
            ];

            const renderNavItems = (containerId, isMobile) => {
                const container = document.getElementById(containerId);
                container.innerHTML = '';
                categories.forEach(cat => {
                    const active = state.currentCategory === cat.id;
                    const btn = document.createElement('button');
                    btn.onclick = () => setCategory(cat.id);
                    
                    if (isMobile) {
                        btn.className = `px-4 py-2 rounded-xl text-xs font-bold transition-all ${
                            active 
                                ? 'bg-violet-600 text-white shadow-md' 
                                : 'text-slate-600 hover:bg-slate-100'
                        }`;
                    } else {
                        btn.className = `px-5 py-2.5 rounded-xl text-sm font-semibold transition-all ${
                            active 
                                ? 'bg-slate-950 text-white shadow-sm' 
                                : 'text-slate-600 hover:text-slate-950 hover:bg-slate-50'
                        }`;
                    }
                    btn.innerText = cat.label;
                    container.appendChild(btn);
                });
            };

            renderNavItems('nav-categories', false);
            renderNavItems('mobile-categories-bar', true);
            
            // Set header active catalog title label
            const headerLabel = categories.find(c => c.id === state.currentCategory);
            document.getElementById('current-category-label').innerText = headerLabel ? headerLabel.label : text.all;
        }

        // Admin Access Modals
        function openAdminModal() {
            state.showDotsMenu = false;
            document.getElementById('dotsDropdown').classList.add('hidden');
            if (state.isAdmin) {
                logoutAdmin();
            } else {
                document.getElementById('admin-modal').classList.remove('hidden');
                document.getElementById('admin-password-input').value = '';
                document.getElementById('login-error').classList.add('hidden');
            }
        }

        // Generates fashion descriptions utilizing Gemini API
        async function generateAIDescription() {
            const text = translations[state.lang];
            const title = document.getElementById('form-title').value.trim();
            const price = document.getElementById('form-price').value;
            const category = document.getElementById('form-category').value;
            const descBtn = document.getElementById('ai-generate-desc-btn');

            if (!title) {
                showToast(text.aiTitleMissing);
                return;
            }

            try {
                showToast(text.aiGeneratingToast);
                descBtn.innerHTML = `<i class="fa-solid fa-circle-notch animate-spin mr-1.5"></i> Working...`;
                descBtn.disabled = true;

                const userPrompt = `Generate a stylish, high-end fashion catalog description for a clothing item titled "${title}", in the category "${category}", priced at ${price} EGP. Craft precisely 2 sentences of luxury, persuasive copy. Use English for the catalog listing.`;
                const systemPrompt = "You are a world-class fashion copywriter for a high-end luxury brand 'Marmar Shopping'. Write in crisp, alluring, premium fashion editor style. Do not use markdown tags, just return plain sentences.";

                const aiOutput = await callGemini(userPrompt, systemPrompt);

                document.getElementById('form-desc').value = aiOutput.trim();
                showToast(text.aiGeneratedSuccess);
            } catch (err) {
                console.error("AI Generation error", err);
                showToast(state.lang === 'ar' ? 'فشل الاتصال بالذكاء الاصطناعي.' : 'AI Generation failed.');
            } finally {
                descBtn.innerHTML = `✨ Write with Gemini AI`;
                descBtn.disabled = false;
                applyLanguageToDOM();
            }
        }

